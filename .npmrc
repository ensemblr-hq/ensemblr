; @electron-forge/plugin-fuses@7 declares a stale peer range (@electron/fuses@^1)
; but works with the @electron/fuses@2 this repo pins. Bun tolerated the mismatch;
; npm's strict peer resolver does not. Relax peer resolution to reproduce the
; same dependency graph that shipped under Bun. Scoped to this repo.
legacy-peer-deps=true
