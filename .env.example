# Absolute path to the App Store Connect API private key downloaded from Users and Access > Integrations.
APPLE_API_KEY_PATH=/absolute/path/to/AuthKey_XXXXXXXXXX.p8
# Key ID shown for that API key in App Store Connect under Users and Access > Integrations.
APPLE_API_KEY_ID=XXXXXXXXXX
# Issuer ID shown in App Store Connect under Users and Access > Integrations.
APPLE_API_ISSUER=00000000-0000-0000-0000-000000000000
