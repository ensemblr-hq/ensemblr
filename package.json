{
	"name": "piductor",
	"productName": "Piductor",
	"version": "0.1.0",
	"description": "A Pi-native macOS workbench for isolated coding-agent workflows.",
	"main": ".vite/build/main.js",
	"private": true,
	"packageManager": "bun@1.3.14",
	"scripts": {
		"dev": "electron-forge start",
		"start": "electron-forge start",
		"check": "biome check . && bun run check:tailwind",
		"check:tailwind": "bun scripts/check-tailwind-classes.mjs",
		"check:fix": "biome check --write .",
		"format": "biome format --write .",
		"lint": "biome lint .",
		"test:config": "ELECTRON_RUN_AS_NODE=1 electron --test tests/main/config-loader.test.ts",
		"test:db": "ELECTRON_RUN_AS_NODE=1 electron --test tests/main/database.test.ts",
		"test:secrets": "ELECTRON_RUN_AS_NODE=1 electron --test tests/main/secret-store.test.ts",
		"typecheck": "tsc --noEmit",
		"build": "electron-forge package",
		"package": "electron-forge package",
		"make": "electron-forge make",
		"doctor": "bunx react-doctor@latest"
	},
	"keywords": [
		"electron",
		"piductor",
		"pi"
	],
	"author": {
		"name": "Philipp Soldunov",
		"email": "69530789+psoldunov@users.noreply.github.com"
	},
	"license": "MIT",
	"dependencies": {
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"electron-squirrel-startup": "^1.0.1",
		"jotai": "^2.20.0",
		"lucide-react": "^1.17.0",
		"radix-ui": "^1.4.3",
		"react": "^19",
		"react-dom": "^19",
		"react-resizable-panels": "^4.11.2",
		"shadcn": "^4.10.0",
		"tailwind-merge": "^3.6.0",
		"tw-animate-css": "^1.4.0"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.16",
		"@electron-forge/cli": "^7.11.2",
		"@electron-forge/maker-deb": "^7.11.2",
		"@electron-forge/maker-rpm": "^7.11.2",
		"@electron-forge/maker-squirrel": "^7.11.2",
		"@electron-forge/maker-zip": "^7.11.2",
		"@electron-forge/plugin-auto-unpack-natives": "^7.11.2",
		"@electron-forge/plugin-fuses": "^7.11.2",
		"@electron-forge/plugin-vite": "^7.11.2",
		"@electron/fuses": "^1.8.0",
		"@tailwindcss/vite": "^4.3.0",
		"@types/electron-squirrel-startup": "^1.0.2",
		"@types/node": "^25.9.1",
		"@types/react": "^19.2.16",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "5.2.0",
		"electron": "^42.3.3",
		"tailwindcss": "^4.3.0",
		"typescript": "^6.0.3",
		"vite": "^5.4.21"
	}
}
